{
  "name": "@askalf/picket",
  "version": "0.1.0",
  "description": "Governed agentic browser — an indirect-prompt-injection firewall and action gate that wraps a CDP browser so agents can read untrusted web pages safely. Part of the Own Your Stack agent-security suite (warden · keeper · canon · cordon).",
  "type": "module",
  "main": "src/index.mjs",
  "bin": {
    "picket": "bin/picket.mjs"
  },
  "scripts": {
    "test": "node --test",
    "demo": "node demo/run-demo.mjs",
    "demo:escalation": "node demo/escalation-demo.mjs",
    "capture:live": "node demo/capture-live.mjs",
    "scan": "node bin/picket.mjs"
  },
  "keywords": [
    "prompt-injection",
    "agent-security",
    "browser-automation",
    "cdp",
    "puppeteer",
    "lethal-trifecta",
    "ai-safety"
  ],
  "dependencies": {
    "node-html-parser": "^6.1.13"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "puppeteer-core": "^22.15.0"
  },
  "license": "MIT",
  "author": "Sprayberry Labs",
  "homepage": "https://github.com/askalf/picket#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/askalf/picket.git"
  },
  "bugs": {
    "url": "https://github.com/askalf/picket/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src",
    "bin",
    "README.md",
    "LICENSE"
  ]
}
